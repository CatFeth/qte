#!/usr/bin/env bash

# 1. Проверка прав (root/sudo)
if [ "$EUID" -ne 0 ]; then
    if command -v sudo &> /dev/null; then
        echo "Перезапуск с правами sudo..."
        exec sudo bash "$0" "$@"
    else
        echo "ОШИБКА: Запустите скрипт от имени root (su -)."
        exit 1
    fi
fi

set -e

echo "--- 1. Обновление и установка базовых утилит ---"
apt update && apt install -y sudo curl ufw nano

echo "--- 2. Настройка Firewall ---"
ufw allow ssh
ufw allow 2222/tcp
ufw allow 443/tcp
ufw default deny incoming
ufw default allow outgoing
ufw --force enable

echo "--- 3. Оптимизация сети (BBR) ---"
if ! grep -q "net.core.default_qdisc=fq" /etc/sysctl.conf; then
    echo "net.core.default_qdisc=fq" >> /etc/sysctl.conf
    echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
    sysctl -p
fi

echo "--- 4. Установка Warp-Native (Авто-ответы) ---"
# Подаем на вход скрипту: 2 (язык), Enter, Пробел (ключ), Enter
printf "2\n \n" | bash <(curl -fsSL https://raw.githubusercontent.com/distillium/warp-native/main/install.sh)

echo "--- 5. Установка Docker ---"
if ! command -v docker &> /dev/null; then
    curl -fsSL https://get.docker.com | sh
fi

echo "--- 6. Настройка Remnanode ---"
mkdir -p /opt/remnanode
cd /opt/remnanode

echo "-------------------------------------------------------"
echo "СЕЙЧАС ОТКРОЕТСЯ NANO."
echo "1. Вставьте конфиг."
echo "2. Нажмите Ctrl+O, Enter (сохранить)."
echo "3. Нажмите Ctrl+X (выйти)."
echo "-------------------------------------------------------"
sleep 2


nano docker-compose.yml < /dev/tty

echo "--- 7. Запуск Docker Compose ---"
docker compose up -d

echo "--- 8. Логи контейнера (Ctrl+C для выхода) ---"
docker compose logs -f -t
